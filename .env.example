# Browser-safe Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SESSION_URL=

# AI scoring and editorial generation
OPENAI_API_KEY=
SCORING_MODEL_FREE=gpt-4.1-mini
SCORING_MODEL_PAID=gpt-5.1
OPENAI_WRITING_MODEL=gpt-5.1
OPENAI_SPEAKING_MODEL=gpt-5.1
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_CONTENT_MODEL=gpt-5.1

# Stripe billing (price IDs are resolved by lookup_key)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Enable only after the Stripe Tax account setup is complete.
STRIPE_AUTOMATIC_TAX=
# Optional validated 40%-off Monthly win-back coupon.
STRIPE_WINBACK_COUPON_ID=
# Optional; the API creates a managed portal configuration when omitted.
STRIPE_PORTAL_CONFIGURATION_ID=

# Lifecycle email and reporting
RESEND_API_KEY=
EMAIL_FROM="IELTS Bank <hello@ielts-bank.com>"
EMAIL_UNSUBSCRIBE_SECRET=
REPORT_FROM="IELTS Bank <hello@ielts-bank.com>"
REPORT_EMAIL=

# Vercel cron authentication (also the unsubscribe-signature fallback)
CRON_SECRET=

# Optional explicit in-content AdSense unit
NEXT_PUBLIC_ADSENSE_SLOT_IN_CONTENT=
