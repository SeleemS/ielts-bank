185,190 L70.87,152.92 A120,120 0 0 1 185,70 Z\" fill=\"#7c3aed\" stroke=\"#ffffff\" stroke-width=\"1.5\"/><text x=\"141.27\" y=\"133.81\" font-family=\"system-ui,-apple-system,Segoe UI,Roboto,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#ffffff\" text-anchor=\"middle\">20%</text><path d=\"M515,190 L515,70 A120,120 0 0 1 612.08,260.53 Z\" fill=\"#0A2540\" stroke=\"#ffffff\" stroke-width=\"1.5\"/><text x=\"581.29\" y=\"160.22\" font-family=\"system-ui,-apple-system,Segoe UI,Roboto,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#ffffff\" text-anchor=\"middle\">35%</text><path d=\"M515,190 L612.08,260.53 A120,120 0 0 1 492.51,307.87 Z\" fill=\"#2563eb\" stroke=\"#ffffff\" stroke-width=\"1.5\"/><text x=\"542.39\" y=\"263.18\" font-family=\"system-ui,-apple-system,Segoe UI,Roboto,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#ffffff\" text-anchor=\"middle\">18%</text><path d=\"M515,190 L492.51,307.87 A120,120 0 0 1 400.87,227.08 Z\" fill=\"#059669\" stroke=\"#ffffff\" stroke-width=\"1.5\"/><text x=\"465.8\" y=\"249.81\" font-family=\"system-ui,-apple-system,Segoe UI,Roboto,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#ffffff\" text-anchor=\"middle\">17%</text><path d=\"M515,190 L400.87,227.08 A120,120 0 0 1 444.47,92.92 Z\" fill=\"#d97706\" stroke=\"#ffffff\" stroke-width=\"1.5\"/><text x=\"444.24\" y=\"171.01\" font-family=\"system-ui,-apple-system,Segoe UI,Roboto,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#ffffff\" text-anchor=\"middle\">20%</text><path d=\"M515,190 L444.47,92.92 A120,120 0 0 1 515,70 Z\" fill=\"#7c3aed\" stroke=\"#ffffff\" stroke-width=\"1.5\"/><text x=\"492.01\" y=\"123.24\" font-family=\"system-ui,-apple-system,Segoe UI,Roboto,sans-serif\" font-size=\"11\" font-weight=\"700\" fill=\"#ffffff\" text-anchor=\"middle\">10%</text><text x=\"185\" y=\"345\" font-family=\"system-ui,-apple-system,Segoe UI,Roboto,sans-serif\" font-size=\"13\" font-weight=\"700\" fill=\"#334155\" text-anchor=\"middle\">